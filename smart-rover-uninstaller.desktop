[Desktop Entry]
Version=1.0
Type=Application
Name=Smart Rover AI Tutor Uninstaller
Comment=Uninstall Smart Rover AI Tutor plugin from Thonny IDE
Exec=bash -c 'SCRIPT_DIR="$(dirname "$(realpath "$1" 2>/dev/null || readlink -f "$1")")"; echo "Working directory: $SCRIPT_DIR"; cd "$SCRIPT_DIR" || { echo "Failed to change to directory"; read -p "Press Enter to close..."; exit 1; }; chmod +x uninstall.sh 2>/dev/null; if [ -f uninstall.sh ]; then ./uninstall.sh; else echo "Error: uninstall.sh not found in $SCRIPT_DIR"; read -p "Press Enter to close..."; exit 1; fi' _ %k
Icon=user-trash
Terminal=true
Categories=Development;Education;
